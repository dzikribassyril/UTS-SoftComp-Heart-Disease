# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Jupyter checkpoints
.ipynb_checkpoints/

# Streamlit local config/state
.streamlit/secrets.toml

# IDE and OS files
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store

# Local logs and environment files
*.log
.env
.env.*

# Project outputs (keep folder, ignore generated contents)
outputs/*
!outputs/.gitkeep
